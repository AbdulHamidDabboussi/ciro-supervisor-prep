{
  "name": "ciro-supervisor-prep",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Practice-exam website for the CIRO Supervisor Exam (static SPA over the repo's question bank).",
  "scripts": {
    "copy-data": "node scripts/copy-data.mjs",
    "validate": "node scripts/validate-data.mjs",
    "predev": "node scripts/copy-data.mjs",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/copy-data.mjs && node scripts/validate-data.mjs && tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
